# MongoDB Atlas connection string
# Replace with your actual Atlas URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/joyverse?retryWrites=true&w=majority

# JWT secret — use a long random string in production (min 32 chars)
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=CHANGE_ME_use_a_long_random_secret_at_least_64_chars

# JWT expiry (e.g. 8h = one school day, 24h for home use)
JWT_EXPIRES_IN=8h

# CORS allowed origins — comma-separated list of your frontend URL(s)
# For local dev: http://localhost:3000
# For production: https://your-app-domain.com
CORS_ORIGINS=http://localhost:3000

# Node environment (use "production" when deploying)
NODE_ENV=development

# Port the API listens on. Most hosts inject PORT automatically; defaults to 4000.
PORT=4000
